<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiflow.backend.dao.VideoDao">
    <resultMap id="videoResultMap" type="com.aiflow.backend.model.Video">
        <id property="id" column="id" />
        <result property="scriptId" column="script_id" />
        <result property="videoUrl" column="video_url" />
        <result property="length" column="length" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <insert id="save" parameterType="com.aiflow.backend.model.Video" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO video (
            script_id,
            video_url,
            length,
            status,
            create_time,
            update_time
        ) VALUES (
            #{scriptId},
            #{videoUrl},
            #{length},
            #{status},
            NOW(),
            NOW()
        )
    </insert>

    <select id="getById" parameterType="java.lang.Long" resultMap="videoResultMap">
        SELECT * FROM video WHERE id = #{id}
    </select>

    <select id="getByScriptId" parameterType="java.lang.Long" resultMap="videoResultMap">
        SELECT * FROM video WHERE script_id = #{scriptId}
    </select>

    <update id="update" parameterType="com.aiflow.backend.model.Video">
        UPDATE video SET
            script_id = #{scriptId},
            video_url = #{videoUrl},
            length = #{length},
            status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM video WHERE id = #{id}
    </delete>

    <delete id="deleteByScriptId" parameterType="java.lang.Long">
        DELETE FROM video WHERE script_id = #{scriptId}
    </delete>
</mapper>