<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiflow.backend.dao.ImageDao">
    <resultMap id="imageResultMap" type="com.aiflow.backend.model.Image">
        <id property="id" column="id" />
        <result property="scriptId" column="script_id" />
        <result property="imageUrl" column="image_url" />
        <result property="shotIndex" column="shot_index" />
        <result property="style" column="style" />
        <result property="createTime" column="create_time" />
    </resultMap>

    <insert id="save" parameterType="com.aiflow.backend.model.Image" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO image (
            script_id,
            image_url,
            shot_index,
            style,
            create_time
        ) VALUES (
            #{scriptId},
            #{imageUrl},
            #{shotIndex},
            #{style},
            NOW()
        )
    </insert>

    <select id="getById" parameterType="java.lang.Long" resultMap="imageResultMap">
        SELECT * FROM image WHERE id = #{id}
    </select>

    <select id="getByScriptId" parameterType="java.lang.Long" resultMap="imageResultMap">
        SELECT * FROM image WHERE script_id = #{scriptId} ORDER BY shot_index ASC
    </select>

    <update id="update" parameterType="com.aiflow.backend.model.Image">
        UPDATE image SET
            script_id = #{scriptId},
            image_url = #{imageUrl},
            shot_index = #{shotIndex},
            style = #{style}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="java.lang.Long">
        DELETE FROM image WHERE id = #{id}
    </delete>

    <delete id="deleteByScriptId" parameterType="java.lang.Long">
        DELETE FROM image WHERE script_id = #{scriptId}
    </delete>
</mapper>