<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiflow.backend.dao.InspirationDao">
    <resultMap id="inspirationResultMap" type="com.aiflow.backend.model.Inspiration">
        <id property="id" column="id" />
        <result property="title" column="title" />
        <result property="sourcePlatform" column="source_platform" />
        <result property="sourceType" column="source_type" />
        <result property="category" column="category" />
        <result property="tags" column="tags" />
        <result property="summary" column="summary" />
        <result property="hotValue" column="hot_value" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <insert id="insert" parameterType="com.aiflow.backend.model.Inspiration" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO inspiration (
            title,
            source_platform,
            source_type,
            category,
            tags,
            summary,
            hot_value,
            status,
            create_time,
            update_time
        ) VALUES (
            #{title},
            #{sourcePlatform},
            #{sourceType},
            #{category},
            #{tags},
            #{summary},
            #{hotValue},
            #{status},
            NOW(),
            NOW()
        )
    </insert>

    <select id="getById" parameterType="java.lang.Long" resultMap="inspirationResultMap">
        SELECT * FROM inspiration WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="inspirationResultMap">
        SELECT * FROM inspiration ORDER BY update_time DESC, id DESC
    </select>
</mapper>
