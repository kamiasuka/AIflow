<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiflow.backend.dao.ProjectDao">
    <resultMap id="projectResultMap" type="com.aiflow.backend.model.Project">
        <id property="id" column="id" />
        <result property="name" column="name" />
        <result property="sourceType" column="source_type" />
        <result property="sourceTitle" column="source_title" />
        <result property="summary" column="summary" />
        <result property="genreTags" column="genre_tags" />
        <result property="status" column="status" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <insert id="insert" parameterType="com.aiflow.backend.model.Project" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO project (
            name,
            source_type,
            source_title,
            summary,
            genre_tags,
            status,
            create_time,
            update_time
        ) VALUES (
            #{name},
            #{sourceType},
            #{sourceTitle},
            #{summary},
            #{genreTags},
            #{status},
            NOW(),
            NOW()
        )
    </insert>

    <select id="getById" parameterType="java.lang.Long" resultMap="projectResultMap">
        SELECT * FROM project WHERE id = #{id}
    </select>

    <select id="findAll" resultMap="projectResultMap">
        SELECT * FROM project ORDER BY update_time DESC, id DESC
    </select>

    <update id="update" parameterType="com.aiflow.backend.model.Project">
        UPDATE project SET
            name = #{name},
            source_type = #{sourceType},
            source_title = #{sourceTitle},
            summary = #{summary},
            genre_tags = #{genreTags},
            status = #{status},
            update_time = NOW()
        WHERE id = #{id}
    </update>
</mapper>
