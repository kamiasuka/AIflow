<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aiflow.backend.dao.GenerationTaskDao">
    <resultMap id="taskResultMap" type="com.aiflow.backend.model.GenerationTask">
        <id property="id" column="id" />
        <result property="projectId" column="project_id" />
        <result property="shotId" column="shot_id" />
        <result property="taskType" column="task_type" />
        <result property="provider" column="provider" />
        <result property="modelName" column="model_name" />
        <result property="promptText" column="prompt_text" />
        <result property="status" column="status" />
        <result property="resultUrl" column="result_url" />
        <result property="errorMessage" column="error_message" />
        <result property="createTime" column="create_time" />
        <result property="updateTime" column="update_time" />
    </resultMap>

    <insert id="insert" parameterType="com.aiflow.backend.model.GenerationTask" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO generation_task (
            project_id,
            shot_id,
            task_type,
            provider,
            model_name,
            prompt_text,
            status,
            result_url,
            error_message,
            create_time,
            update_time
        ) VALUES (
            #{projectId},
            #{shotId},
            #{taskType},
            #{provider},
            #{modelName},
            #{promptText},
            #{status},
            #{resultUrl},
            #{errorMessage},
            NOW(),
            NOW()
        )
    </insert>

    <select id="getById" parameterType="java.lang.Long" resultMap="taskResultMap">
        SELECT * FROM generation_task WHERE id = #{id}
    </select>

    <select id="findByProjectId" parameterType="java.lang.Long" resultMap="taskResultMap">
        SELECT * FROM generation_task WHERE project_id = #{projectId} ORDER BY create_time DESC, id DESC
    </select>

    <select id="findByShotId" parameterType="java.lang.Long" resultMap="taskResultMap">
        SELECT * FROM generation_task WHERE shot_id = #{shotId} ORDER BY create_time DESC, id DESC
    </select>

    <update id="update" parameterType="com.aiflow.backend.model.GenerationTask">
        UPDATE generation_task SET
            provider = #{provider},
            model_name = #{modelName},
            prompt_text = #{promptText},
            status = #{status},
            result_url = #{resultUrl},
            error_message = #{errorMessage},
            update_time = NOW()
        WHERE id = #{id}
    </update>
</mapper>
